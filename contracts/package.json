{
  "name": "@fission/contracts",
  "version": "0.0.1",
  "private": true,
  "description": "Fission Protocol — yield tokenization on Hedera. Foundry-first; Hardhat for Hedera deploy + verify.",
  "license": "MIT",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:ci": "FOUNDRY_PROFILE=ci forge test",
    "test:deep": "FOUNDRY_PROFILE=deep forge test",
    "fuzz": "forge test --match-test 'invariant_|test_fuzz_'",
    "coverage": "forge coverage --report lcov --report summary",
    "snapshot": "forge snapshot",
    "format": "forge fmt",
    "lint": "forge fmt --check && slither src",
    "slither": "slither src --config-file ../.github/slither.config.json",
    "aderyn": "aderyn .",
    "medusa": "medusa fuzz --config medusa.json",
    "compile:hardhat": "hardhat compile",
    "deploy:testnet": "hardhat run script/deploy.ts --network hederaTestnet",
    "deploy:mainnet": "hardhat run script/deploy.ts --network hederaMainnet",
    "verify": "node script/verify-hashscan.mjs"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-foundry": "^1.1.3",
    "@hashgraph/sdk": "^2.85.0",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.26.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.2"
  }
}
