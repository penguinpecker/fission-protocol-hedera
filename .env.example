# ─── Hedera deployer ───────────────────────────────────────────────
HEDERA_NETWORK=mainnet                # mainnet | testnet | previewnet
HEDERA_OPERATOR_ID=0.0.XXXXXX         # Hedera account id
HEDERA_OPERATOR_KEY=0x...             # ECDSA private key (used as EVM signer too)

# ─── RPC ───────────────────────────────────────────────────────────
HEDERA_MAINNET_RPC=https://mainnet.hashio.io/api
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
HEDERA_MIRROR_NODE_MAINNET=https://mainnet-public.mirrornode.hedera.com
HEDERA_MIRROR_NODE_TESTNET=https://testnet.mirrornode.hedera.com

# ─── Governance ────────────────────────────────────────────────────
PROTOCOL_MULTISIG=0x...               # 3-of-5 ProtocolMultisig contract address
TIMELOCK_DELAY_SECONDS=172800         # 48h between propose and execute

# ─── Keeper (rate poster) ──────────────────────────────────────────
KEEPER_ACCOUNT_ID=0.0.XXXXXX
KEEPER_PRIVATE_KEY=0x...
KEEPER_INTERVAL_SECONDS=3600

# ─── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_HEDERA_NETWORK=mainnet
NEXT_PUBLIC_RPC_URL=https://mainnet.hashio.io/api
NEXT_PUBLIC_MIRROR_NODE_URL=https://mainnet-public.mirrornode.hedera.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_FACTORY_ADDRESS=0x...
NEXT_PUBLIC_ROUTER_ADDRESS=0x...
